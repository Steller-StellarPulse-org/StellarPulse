# StellarPulse Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Soroban RPC URL (Testnet)
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Horizon URL (Testnet)
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
# Network passphrase
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
# Friendbot URL (Testnet)
NEXT_PUBLIC_FRIENDBOT_URL=https://friendbot.stellar.org

# Deployed contract IDs (replace with actual deployed addresses)
NEXT_PUBLIC_MARKET_CONTRACT_ID=
NEXT_PUBLIC_TOKEN_CONTRACT_ID=
NEXT_PUBLIC_REFERRAL_CONTRACT_ID=
NEXT_PUBLIC_LEADERBOARD_CONTRACT_ID=

# Native XLM Stellar Asset Contract address
NEXT_PUBLIC_XLM_SAC_ID=

# Admin public key
NEXT_PUBLIC_ADMIN_PUBLIC_KEY=GDHQ6TNWZ4V2JVCDWEUVW7YKFBXCOQZRRUCT27LAKES3PGOE6JSZMSMD

# App URL (used for OG meta tags and canonical links)
NEXT_PUBLIC_APP_URL=https://stellarpulse.app

# ── RPC Proxy (security + scale) ──────────────────────────────────────────────
# The browser talks to our own /api/rpc proxy, which forwards to the REAL RPC
# below. These two vars are SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix) so the
# paid RPC URL never ships in the browser bundle and randoms can't burn credits.
#
# Read/write RPC split (cost optimization):
#   • READS  (markets, leaderboard, balances, simulate) → PUBLIC_RPC_URL — free,
#     high-volume, safe to retry. Don't burn paid credits here.
#   • WRITES (place_bet, claim — sendTransaction) → SOROBAN_RPC_URL — your paid
#     QuickNode endpoint, for reliability where money actually moves.
#
# SOROBAN_RPC_URL — your real (e.g. QuickNode) Soroban RPC endpoint (WRITES).
#   If unset, falls back to PUBLIC_RPC_URL.
SOROBAN_RPC_URL=https://your-endpoint.quiknode.pro/xxxxxxxx/
#
# PUBLIC_RPC_URL — RPC used for all READS. Defaults to the community RPC.
#   Leaving this as the public RPC keeps QuickNode credits spent on writes only.
# PUBLIC_RPC_URL=https://mainnet.sorobanrpc.com
#
# ALLOWED_ORIGINS — comma-separated list of origins allowed to use the proxy.
#   Requests from any other origin get 403. Set this to your deployed URL(s).
#   (Vercel's own deployment URL is auto-allowed via VERCEL_URL.)
ALLOWED_ORIGINS=https://stellarpulse.app
#
# NEXT_PUBLIC_RPC_PROXY=off — set to bypass the proxy and hit the RPC directly
#   from the browser (local debugging only). Leave unset in production.
# NEXT_PUBLIC_RPC_PROXY=
