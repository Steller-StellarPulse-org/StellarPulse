# ── PULSE Testnet Deploy Secrets ──────────────────────────────────────────
# Copy this file to .deploy.env and fill in your values.
# .deploy.env is git-ignored — NEVER commit it.
#
# How to get a funded testnet keypair:
#   stellar keys generate deployer --network testnet
#   stellar keys show deployer           (shows public key)
#   stellar keys show deployer --show-secret  (shows secret key)
#   curl "https://friendbot.stellar.org?addr=<PUBLIC_KEY>"
#
# Or paste in an existing keypair you control.

# Your deployer/admin Stellar secret key (S...)
# This account will be the contract admin and must hold XLM for fees.
DEPLOYER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: separate sponsor account for fee-bump transactions.
# Leave blank to skip fee sponsorship setup.
# On testnet this is fine to leave blank (users can pay their own fees).
SPONSOR_SECRET=

# Optional: a separate resolver address (public key G...) to add after deploy.
# Leave blank to skip. You can always add resolvers via the admin UI later.
RESOLVER_PUBLIC_KEY=

